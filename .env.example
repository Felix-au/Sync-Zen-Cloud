# ── MongoDB ─────────────────────────────────────────────────────────────────
# MongoDB Atlas or self-hosted connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/syncstay?retryWrites=true&w=majority

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
# Required by Auth.js v5 outside Vercel — set to true for local dev and self-hosted prod
AUTH_TRUST_HOST=true

# ── Google Drive (Service Account) ──────────────────────────────────────────
# Paste the ENTIRE contents of your service account JSON key as a
# single-line JSON string (escape inner quotes if needed), OR set the
# path to the JSON file. The app reads GOOGLE_SA_KEY as a JSON string.
GOOGLE_SA_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Drive folder ID to upload files into (optional — uploads to root if blank)
GOOGLE_DRIVE_FOLDER_ID=

# ── Super Admin Bootstrap ────────────────────────────────────────────────────
# POST /api/seed to create the first super-admin account
SUPER_ADMIN_EMAIL=admin@syncstay.com
SUPER_ADMIN_PASSWORD=change-me-immediately
