# ── MongoDB ─────────────────────────────────────────────────────────────────
# MongoDB Atlas or self-hosted connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/syncstay?retryWrites=true&w=majority

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
# Required by Auth.js v5 outside Vercel — set to true for local dev and self-hosted prod
AUTH_TRUST_HOST=true

# ── Cloudinary (File Storage) ────────────────────────────────────────────────
# Cloudinary account credentials for storing uploaded guest photos and ID proofs
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Super Admin Bootstrap ────────────────────────────────────────────────────
# POST /api/seed to create the first super-admin account
SUPER_ADMIN_EMAIL=admin@syncstay.com
SUPER_ADMIN_PASSWORD=change-me-immediately
